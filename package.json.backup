{
  "name": "eternal-ui",
  "private": true,
  "description": "The ultimate visual website builder",
  "author": "Eternal UI Team",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "analyze": "cross-env ANALYZE=true next build",
    "lighthouse": "lhci autorun",
    "sitemap": "next-sitemap",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.57.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "npm@10.2.0",
  "dependencies": {
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.28.0",
    "@babel/types": "^7.28.1",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.21",
    "uuid": "^11.1.0",
    "web-vitals": "^5.0.3"
  },
  "version": "1.0.0",
  "main": "jest.setup.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronAPerez/eternal-ui.git"
  },
  "keywords": [],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/AaronAPerez/eternal-ui/issues"
  },
  "homepage": "https://github.com/AaronAPerez/eternal-ui#readme"
}
