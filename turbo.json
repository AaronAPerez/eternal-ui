{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
           "outputs": [".next/**", "!.next/cache/**"]
    },
    "export-demo:build": {
      "dependsOn": ["@eternal-ui/core#build"],
      "outputs": [".next/**"]
    },
    "export-demo:test": {
      "dependsOn": ["@eternal-ui/core#build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false
    },
    "lint": {},
    "typecheck": {}
  }
}