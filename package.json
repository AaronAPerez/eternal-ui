{
  "name": "eternal-ui",
  "version": "1.0.0",
  "private": true,
  "description": "The ultimate visual website builder",
  "author": "Eternal UI Team",
  "license": "MIT",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "analyze": "cross-env ANALYZE=true next build",
    "lighthouse": "lhci autorun",
    "sitemap": "next-sitemap",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.57.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.11",
    "turbo": "^2.5.4",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.28.0",
    "@babel/types": "^7.28.1",
    "@heroicons/react": "^2.2.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.6",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.21",
    "react-confetti": "^6.4.0",
    "react-intersection-observer": "^9.16.0",
    "recharts": "^3.1.0",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "web-vitals": "^5.0.3"
  },
  "main": "jest.setup.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AaronAPerez/eternal-ui.git"
  },
  "keywords": [],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/AaronAPerez/eternal-ui/issues"
  },
  "homepage": "https://github.com/AaronAPerez/eternal-ui#readme"
}
