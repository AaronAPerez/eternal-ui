{
  "name": "eternal-ui",
  "private": true,
  "description": "The ultimate visual website builder",
  "author": "Eternal UI Team",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.0",
    "eslint": "^8.57.0",
    "prettier": "^3.6.2",
    "turbo": "^2.5.4",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "npm@10.2.0",
  "dependencies": {
    "@babel/generator": "^7.28.0",
    "@babel/parser": "^7.28.0",
    "@babel/types": "^7.28.1",
    "jszip": "^3.10.1",
    "lodash-es": "^4.17.21",
    "uuid": "^11.1.0",
    "web-vitals": "^5.0.3"
  }
}
