{
  "name": "@eternal-ui/ai-engine",
  "version": "1.0.0",
  "description": "Enhanced AI Component Generator for Eternal UI - The competitive differentiator",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix"
  },
  "keywords": [
    "ai",
    "component-generation",
    "code-generation",
    "react",
    "typescript",
    "accessibility",
    "performance",
    "brand-intelligence"
  ],
  "author": "Eternal UI Team",
  "license": "MIT",
  "dependencies": {
    "openai": "^4.52.0",
    "zod": "^3.22.4",
    "axios": "^1.6.8",
    "cheerio": "^1.0.0-rc.12",
    "lodash": "^4.17.21",
    "uuid": "^9.0.1",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/lodash": "^4.17.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.7.0",
    "@typescript-eslint/parser": "^7.7.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.12",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5",
    "prettier": "^3.2.5",
    "@types/cheerio": "^0.22.35"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./enhanced-generator": {
      "import": "./dist/enhanced-generator.js",
      "require": "./dist/enhanced-generator.js",
      "types": "./dist/enhanced-generator.d.ts"
    },
    "./brand-intelligence": {
      "import": "./dist/brand-intelligence.js",
      "require": "./dist/brand-intelligence.js",
      "types": "./dist/brand-intelligence.d.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}